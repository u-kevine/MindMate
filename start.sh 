#!/bin/bash
# ============================================================
#  MindMate — Dev Startup Script
# ============================================================

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}🌿 MindMate — Démarrage de l'environnement de développement${NC}\n"

# ── Backend ───────────────────────────────────────────────────
echo -e "${BLUE}▶ Démarrage du backend Django...${NC}"
cd backend

if [ ! -d "venv" ]; then
  echo "  Création de l'environnement virtuel..."
  python3 -m venv venv
fi

source venv/bin/activate

pip install -r requirements.txt -q

if [ ! -f ".env" ]; then
  cp .env.example .env
  echo -e "${YELLOW}  ⚠️  Fichier .env créé depuis .env.example. Modifiez-le avec vos paramètres DB.${NC}"
fi

python manage.py migrate --run-syncdb 2>/dev/null || true

# Start Django in background
python manage.py runserver 0.0.0.0:8000 &
DJANGO_PID=$!
echo -e "${GREEN}  ✅ API Django → http://localhost:8000/api/v1/${NC}"
echo -e "${GREEN}  ✅ Admin     → http://localhost:8000/admin/${NC}"
echo -e "${GREEN}  ✅ API Docs  → http://localhost:8000/api/docs/${NC}"

cd ..

# ── Frontend ──────────────────────────────────────────────────
echo -e "\n${BLUE}▶ Démarrage du frontend React...${NC}"
cd frontend

if [ ! -d "node_modules" ]; then
  echo "  Installation des dépendances npm..."
  npm install
fi

npm run -- --host 0.0.0.0 --port 3000 &
REACT_PID=$!
echo -e "${GREEN}  ✅ App React → http://localhost:3000${NC}"

cd ..

echo -e "\n${GREEN}═══════════════════════════════════════${NC}"
echo -e "${GREEN}  MindMate est opérationnel ! 🌿${NC}"
echo -e "${GREEN}  Appuyez sur Ctrl+C pour arrêter.${NC}"
echo -e "${GREEN}═══════════════════════════════════════${NC}\n"

# Wait and cleanup on exit
trap "kill $DJANGO_PID $REACT_PID 2>/dev/null; echo -e '\n${YELLOW}MindMate arrêté.${NC}'" EXIT
wait