# =============================================================================
#  MindMate — Environment Variables
#  File location: mindmate/backend/.env.example
#
#  HOW TO USE
#  ----------
#  1. Copy this file:   cp .env.example .env
#  2. Fill in every value marked  ← CHANGE THIS
#  3. Never commit .env to version control  (.gitignore already excludes it)
#
#  SECURITY RULES
#  --------------
#  - SECRET_KEY must be at least 50 random characters in production
#  - DB_PASSWORD must be strong (16+ chars, mixed case, numbers, symbols)
#  - DEBUG must be False in production
#  - ALLOWED_HOSTS must list only your actual domain(s) in production
#
#  Generate a strong SECRET_KEY with:
#      python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# =============================================================================


# =============================================================================
# DJANGO CORE
# =============================================================================

# Set to False in staging and production — True only for local development
DEBUG=True

# Long random string — must be unique, secret, and never shared
# CHANGE THIS before deploying to any non-local environment
SECRET_KEY=mindmate-local-dev-insecure-key-change-before-any-deployment!!

# Comma-separated list of hostnames Django will serve
# Development: localhost,127.0.0.1
# Production:  yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Django's internal settings module path — do not change
DJANGO_SETTINGS_MODULE=mindmate_project.settings

# Application timezone — Africa/Kigali for Rwanda
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Africa/Kigali


# =============================================================================
# DATABASE  (PostgreSQL)
# =============================================================================

# Name of the PostgreSQL database
# Must match POSTGRES_DB in docker-compose.yml
DB_NAME=mindmate_db

# PostgreSQL username with full privileges on DB_NAME
# Must match POSTGRES_USER in docker-compose.yml
DB_USER=mindmate_user

# PostgreSQL password  ← CHANGE THIS in every environment
# Must match POSTGRES_PASSWORD in docker-compose.yml
DB_PASSWORD=mindmate_pass

# Hostname of the database server
# Docker Compose: use the service name "db"
# Local (no Docker): use "localhost"
DB_HOST=localhost

# PostgreSQL port — default is 5432, only change if you customised it
DB_PORT=5432


# =============================================================================
# REDIS  (Celery broker + result backend + Django cache)
# =============================================================================

# Full Redis connection URL
# Docker Compose: redis://redis:6379/0   (service name "redis")
# Local (no Docker): redis://localhost:6379/0
# With password:     redis://:your_password@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Redis database index used for the Django cache (separate from Celery's /0)
# Keeping them on different DB indices avoids cache keys clashing with task keys
REDIS_CACHE_DB=1


# =============================================================================
# JWT AUTHENTICATION  (djangorestframework-simplejwt)
# =============================================================================

# How long an access token is valid (in minutes)
# Short for security — client must refresh using the refresh token
ACCESS_TOKEN_LIFETIME_MINUTES=60

# How long a refresh token is valid (in days)
# Set to 1 in high-security environments; 7 is comfortable for students
REFRESH_TOKEN_LIFETIME_DAYS=7


# =============================================================================
# CORS  (Cross-Origin Resource Sharing)
# =============================================================================

# Comma-separated list of origins allowed to make cross-site requests
# Must include the React dev server origin in development
# In production replace with your actual frontend URL (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://cautious-space-funicular-wr5g7grq456gc5pqv-3000.app.github.dev,https://cautious-space-funicular-wr5g7grq456gc5pqv-8000.app.github.dev

# Set to True only if your frontend needs to send cookies or auth headers
# cross-origin (JWT in Authorization header does NOT require this)
CORS_ALLOW_CREDENTIALS=True


# =============================================================================
# EMAIL  (SMTP — used by Celery tasks for notifications)
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-real-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=MindMate <your-real-gmail@gmail.com>



# =============================================================================
# STATIC & MEDIA FILES
# =============================================================================

# Absolute filesystem path to the directory that collectstatic will write to
# Gunicorn serves this via WhiteNoise; Nginx serves it directly in production
STATIC_ROOT=/app/staticfiles

# URL prefix for static files
STATIC_URL=/static/

# Absolute filesystem path for user-uploaded files (avatars, resource attachments)
MEDIA_ROOT=/app/media

# URL prefix for media files
MEDIA_URL=/media/


# =============================================================================
# GUNICORN  (production WSGI server — used when CMD is not overridden)
# =============================================================================

# Number of worker processes
# Rule of thumb: (2 × CPU cores) + 1
# A 1-core container → 3 workers; 2-core → 5 workers
GUNICORN_WORKERS=3

# Threads per worker — mild concurrency for I/O-bound views
GUNICORN_THREADS=2

# Request timeout in seconds — increase for slow report generation queries
GUNICORN_TIMEOUT=120

# Host and port Gunicorn binds to inside the container
GUNICORN_BIND=0.0.0.0:8000


# =============================================================================
# CELERY  (background task workers)
# =============================================================================

# Number of concurrent worker processes per Celery worker container
# Reduce to 2 on constrained VMs; raise to 8+ on dedicated task servers
CELERY_WORKER_CONCURRENCY=4

# Maximum tasks a worker processes before gracefully restarting
# Prevents slow memory leaks in long-running workers
CELERY_MAX_TASKS_PER_CHILD=100

# Log level for Celery worker and beat output
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
CELERY_LOG_LEVEL=info


# =============================================================================
# SECURITY  (production hardening — has no effect when DEBUG=True)
# =============================================================================

# Force HTTPS — set to True once you have an SSL certificate
# HTTPS=False

# HSTS header duration in seconds (31536000 = 1 year)
# SECURE_HSTS_SECONDS=31536000

# Set to True to also apply HSTS to subdomains
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# Set to True to submit your domain to the HSTS preload list
# SECURE_HSTS_PRELOAD=True

# Redirect all HTTP to HTTPS
# SECURE_SSL_REDIRECT=True

# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True


# =============================================================================
# LOGGING  (optional overrides)
# =============================================================================

# Log level for Django's root logger
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Absolute path to a log file (leave blank to log to stdout only)
# LOG_FILE=/app/logs/mindmate.log


# =============================================================================
# FEATURE FLAGS  (optional — extend in settings.py as needed)
# =============================================================================

# Maximum file size for resource uploads in bytes (default: 10 MB)
MAX_UPLOAD_SIZE=10485760

# Number of days of inactivity before a support case is flagged as overdue
# (used by the Celery beat task alert_overdue_cases)
OVERDUE_CASE_THRESHOLD_DAYS=3

# Enable or disable the daily email digest for unread messages
# Set to False during testing to suppress notification emails
ENABLE_MESSAGE_DIGEST=True